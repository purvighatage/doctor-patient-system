    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Update Temp Password",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "<REPLACE_WITH_DOCTOR_TOKEN_FROM_LOGIN>", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"<TEMP_PASSWORD>\",\n  \"newPassword\": \"newsecurepassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/doctors/password",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "doctors", "password"]
            }
          }
        },
        {
